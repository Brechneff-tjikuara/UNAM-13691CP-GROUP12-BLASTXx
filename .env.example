# BlastX Environment Variables
# Duplicate this file to .env and fill in your keys

# Email Provider Keys
SENDGRID_API_KEY=your_sendgrid_key_here
MAILCHIMP_API_KEY=your_mailchimp_key_here

# SMS Provider Keys
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# App Config
API_URL=https://api.blastx.com/v1
DEBUG=true
